{% extends 'base.html.twig' %}

{% block body %}

	<h1 class="text-2xl font-bold mb-6">Applications</h1>

	<div
		class="grid grid-cols-1 lg:grid-cols-3 gap-6">

		<!-- Create -->
		<div class="bg-white p-6 rounded shadow">
			<h2 class="font-semibold mb-3">Create Application</h2>

			<form id="createApp" class="space-y-2">

				<select name="candidate_id" class="w-full border rounded px-2 py-1">
					{% for c in candidates %}
						<option value="{{ c.id }}">{{ c.name }}</option>
					{% endfor %}
				</select>

				<select name="vacancy_id" class="w-full border rounded px-2 py-1">
					{% for v in vacancies %}
						<option value="{{ v.id }}">{{ v.title }}
							({{ v.companyName }})</option>
					{% endfor %}
				</select>

				<button class="w-full bg-blue-600 text-white py-2 rounded">
					Create
				</button>
			</form>
		</div>

		<!-- Table -->
		<div class="lg:col-span-2 bg-white p-6 rounded shadow">
			<table class="w-full text-left">
				<thead>
					<tr class="border-b text-sm text-gray-500">
						<th class="py-2">Candidate</th>
						<th>Vacancy</th>
						<th>Stage</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					{% for a in applications %}
						<tr class="border-b">
							<td class="py-2">{{ a.candidate.name }}</td>
							<td>{{ a.vacancy.title }}</td>
							<td>{{ a.stage }}</td>
							<td class="text-right">
								<button onclick="nextStage({{ a.id }})" class="text-blue-500 text-sm hover:underline">
									Next →
								</button>
								<button onclick="deleteApp({{ a.id }})" class="text-red-500 text-sm ml-2">
									Delete
								</button>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>

	 <script>
	// create
	document.getElementById('createApp').addEventListener('submit', async (e) => {
	    e.preventDefault();

	    const f = e.target;

	    await fetch('/api/applications', {
	        method: 'POST',
	        headers: { 'Content-Type': 'application/json' },
	        body: JSON.stringify({
	            candidate_id: f.candidate_id.value,
	            vacancy_id: f.vacancy_id.value
	        })
	    });

	    location.reload();
	});

	//Next stage
	async function nextStage(id) {
	    await fetch(`/api/applications/${id}/stage`, { method: 'PATCH' });
	    location.reload();
	}

	// del
	async function deleteApp(id) {
	    await fetch(`/api/applications/${id}`, { method: 'DELETE' });
	    location.reload();
	}
	</script>

{% endblock %}

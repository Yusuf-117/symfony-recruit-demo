<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>RecruitFlow Mini</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-900">

<div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white p-6">
        <h1 class="text-xl font-bold mb-6">RecruitFlow</h1>

        <nav class="space-y-2">
            <a href="/dashboard" class="block px-3 py-2 rounded hover:bg-gray-800">Dashboard</a>
            <a href="/candidates" class="block px-3 py-2 rounded hover:bg-gray-800">Candidates</a>
            <a href="/vacancies" class="block px-3 py-2 rounded hover:bg-gray-800">Vacancies</a>
            <a href="/applications" class="block px-3 py-2 rounded hover:bg-gray-800">Applications</a>
            <a href="/pipeline" class="block px-3 py-2 rounded hover:bg-gray-800">Pipeline</a>
        </nav>
    </aside>

    <!-- Content -->
    <main class="flex-1 p-8">
        {% block body %}{% endblock %}
    </main>
</div>

</body>
</html>
